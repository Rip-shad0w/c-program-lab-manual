#include <stdio.h>
int main() {
    int s=0,c,d;
    printf("enter the digit: ");
    scanf("%d",&c);
    while(c>0){
        d=c%10;
            if (d==6||d==0||d==4||d==9){
                s=s+1;}
            else if(d==8){
                s=s+2;}
        c=c/10;}
    printf("%d",s);
    return 0;}
